{
  "name": "@loginov-rocks/loginov-rocks-shared",
  "version": "2.9.0",
  "private": true,
  "description": "Shared",
  "homepage": "https://loginov.rocks",
  "bugs": {
    "url": "https://github.com/loginov-rocks/loginov-rocks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loginov-rocks/loginov-rocks.git"
  },
  "license": "MIT",
  "author": "Danila Loginov <danila@loginov.rocks> (https://loginov.rocks)",
  "type": "module",
  "exports": "./dist/index.js",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "coverage": "rimraf coverage && npm run test:coverage",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "package": "npm pack && mv loginov-rocks-loginov-rocks-shared-*.tgz loginov-rocks-loginov-rocks-shared.tgz",
    "test": "jest",
    "test:coverage": "npm test -- --coverage",
    "test:update": "npm test -- --updateSnapshot",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.ts"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "babel-jest": "^30.4.1",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-cloudfront": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
