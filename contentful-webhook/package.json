{
  "name": "@loginov-rocks/loginov-rocks-contentful-webhook",
  "version": "2.9.0",
  "private": true,
  "description": "Contentful Webhook",
  "homepage": "https://loginov.rocks",
  "bugs": {
    "url": "https://github.com/loginov-rocks/loginov-rocks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loginov-rocks/loginov-rocks.git"
  },
  "license": "MIT",
  "author": "Danila Loginov <danila@loginov.rocks> (https://loginov.rocks)",
  "type": "module",
  "scripts": {
    "coverage": "rimraf coverage && npm run test:coverage",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "package": "rimraf contentful-webhook.zip && (cd src && zip -r ../contentful-webhook.zip . -x '*.test.ts' '*__fixtures__*') && zip -r contentful-webhook.zip package.json node_modules/@loginov-rocks/loginov-rocks-shared",
    "shared:copy": "cp ../shared/loginov-rocks-loginov-rocks-shared.tgz .",
    "shared:install": "npm install loginov-rocks-loginov-rocks-shared.tgz",
    "shared:update": "npm run shared:copy && npm run shared:install",
    "test": "jest",
    "test:coverage": "npm test -- --coverage",
    "test:update": "npm test -- --updateSnapshot",
    "typecheck": "tsc"
  },
  "jest": {
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.ts"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1068.0",
    "@aws-sdk/client-secrets-manager": "^3.1068.0",
    "@aws-sdk/client-sqs": "^3.1068.0",
    "@loginov-rocks/loginov-rocks-shared": "file:loginov-rocks-loginov-rocks-shared.tgz"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "babel-jest": "^30.4.1",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
