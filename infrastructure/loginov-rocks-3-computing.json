{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Parameters": {
    "DataGithubFileKey": {
      "Type": "String",
      "Description": "GitHub file key in Data bucket",
      "Default": "github.json"
    },
    "DistributionStackName": {
      "Type": "String",
      "Description": "Name of previously deployed \"Distribution\" CloudFormation Stack"
    },
    "PersistentStackName": {
      "Type": "String",
      "Description": "Name of previously deployed \"Persistent\" CloudFormation Stack"
    },
    "UpdateGithubGithubBaseUrl": {
      "Type": "String",
      "Description": "GitHub base URL for Update Github",
      "Default": "https://api.github.com"
    },
    "WebAppLambdaInvalidationPath": {
      "Type": "String",
      "Description": "Invalidation path for Web App CloudFront Distribution to invalidate after static site generation done by Web App",
      "Default": "/*"
    }
  },
  "Resources": {
    "UpdateGithubRule": {
      "Type": "AWS::Events::Rule",
      "Properties": {
        "Name": {
          "Fn::Sub": "${AWS::StackName}-update-github-rule"
        },
        "ScheduleExpression": "rate(1 day)",
        "Targets": [
          {
            "Arn": {
              "Fn::GetAtt": [
                "UpdateGithubFunction",
                "Arn"
              ]
            },
            "Id": "UpdateGithubRuleTarget"
          }
        ]
      }
    },
    "CdPolicy": {
      "Type": "AWS::IAM::ManagedPolicy",
      "Properties": {
        "ManagedPolicyName": {
          "Fn::Sub": "${AWS::StackName}-cd-policy"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:GetObject",
                "s3:PutObject"
              ],
              "Resource": [
                {
                  "Fn::Sub": [
                    "${DeploymentBucketArn}/contentful-webhook.zip",
                    {
                      "DeploymentBucketArn": {
                        "Fn::ImportValue": {
                          "Fn::Sub": "${PersistentStackName}-DeploymentBucketArn"
                        }
                      }
                    }
                  ]
                },
                {
                  "Fn::Sub": [
                    "${DeploymentBucketArn}/update-github.zip",
                    {
                      "DeploymentBucketArn": {
                        "Fn::ImportValue": {
                          "Fn::Sub": "${PersistentStackName}-DeploymentBucketArn"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": "lambda:UpdateFunctionCode",
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "ContentfulWebhookFunction",
                    "Arn"
                  ]
                },
                {
                  "Fn::GetAtt": [
                    "UpdateGithubFunction",
                    "Arn"
                  ]
                },
                {
                  "Fn::GetAtt": [
                    "WebAppFunction",
                    "Arn"
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": "secretsmanager:GetSecretValue",
              "Resource": {
                "Fn::ImportValue": {
                  "Fn::Sub": "${PersistentStackName}-SecretArn"
                }
              }
            },
            {
              "Effect": "Allow",
              "Action": [
                "s3:ListBucket",
                "s3:GetObject"
              ],
              "Resource": [
                {
                  "Fn::ImportValue": {
                    "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                  }
                },
                {
                  "Fn::Sub": [
                    "${DataBucketArn}/${DataGithubFileKey}",
                    {
                      "DataBucketArn": {
                        "Fn::ImportValue": {
                          "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": "ecr:GetAuthorizationToken",
              "Resource": "*"
            },
            {
              "Effect": "Allow",
              "Action": [
                "ecr:CompleteLayerUpload",
                "ecr:UploadLayerPart",
                "ecr:InitiateLayerUpload",
                "ecr:BatchCheckLayerAvailability",
                "ecr:PutImage"
              ],
              "Resource": {
                "Fn::ImportValue": {
                  "Fn::Sub": "${PersistentStackName}-WebAppRepositoryArn"
                }
              }
            }
          ]
        }
      }
    },
    "DevPolicy": {
      "Type": "AWS::IAM::ManagedPolicy",
      "Properties": {
        "ManagedPolicyName": {
          "Fn::Sub": "${AWS::StackName}-dev-policy"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "secretsmanager:GetSecretValue",
              "Resource": {
                "Fn::ImportValue": {
                  "Fn::Sub": "${PersistentStackName}-SecretArn"
                }
              }
            },
            {
              "Effect": "Allow",
              "Action": [
                "s3:ListBucket",
                "s3:GetObject"
              ],
              "Resource": [
                {
                  "Fn::ImportValue": {
                    "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                  }
                },
                {
                  "Fn::Sub": [
                    "${DataBucketArn}/${DataGithubFileKey}",
                    {
                      "DataBucketArn": {
                        "Fn::ImportValue": {
                          "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": "ecr:GetAuthorizationToken",
              "Resource": "*"
            },
            {
              "Effect": "Allow",
              "Action": [
                "ecr:CompleteLayerUpload",
                "ecr:UploadLayerPart",
                "ecr:InitiateLayerUpload",
                "ecr:BatchCheckLayerAvailability",
                "ecr:PutImage"
              ],
              "Resource": {
                "Fn::ImportValue": {
                  "Fn::Sub": "${PersistentStackName}-WebAppRepositoryArn"
                }
              }
            },
            {
              "Effect": "Allow",
              "Action": [
                "s3:ListBucket",
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
              ],
              "Resource": [
                {
                  "Fn::ImportValue": {
                    "Fn::Sub": "${PersistentStackName}-WebAppBucketArn"
                  }
                },
                {
                  "Fn::Sub": [
                    "${WebAppBucketArn}/*",
                    {
                      "WebAppBucketArn": {
                        "Fn::ImportValue": {
                          "Fn::Sub": "${PersistentStackName}-WebAppBucketArn"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": "cloudfront:CreateInvalidation",
              "Resource": {
                "Fn::Sub": [
                  "arn:aws:cloudfront::${AWS::AccountId}:distribution/${DistributionId}",
                  {
                    "DistributionId": {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${DistributionStackName}-DistributionId"
                      }
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    },
    "ContentfulWebhookFunctionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "logs:CreateLogGroup",
                  "Resource": {
                    "Fn::Sub": "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:*"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": {
                    "Fn::Sub": [
                      "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/${FunctionName}:*",
                      {
                        "FunctionName": {
                          "Fn::Sub": "${AWS::StackName}-contentful-webhook-function"
                        }
                      }
                    ]
                  }
                }
              ]
            },
            "PolicyName": "AWSLambdaBasicExecutionRole"
          },
          {
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "secretsmanager:GetSecretValue",
                  "Resource": {
                    "Fn::ImportValue": {
                      "Fn::Sub": "${PersistentStackName}-SecretArn"
                    }
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "sqs:SendMessage",
                  "Resource": {
                    "Fn::ImportValue": {
                      "Fn::Sub": "${PersistentStackName}-QueueArn"
                    }
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "ssm:GetParameter",
                  "Resource": [
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-ContentfulWebhookPasswordParameterArn"
                      }
                    },
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-ContentfulWebhookUsernameParameterArn"
                      }
                    }
                  ]
                }
              ]
            },
            "PolicyName": "CustomPolicy"
          }
        ],
        "RoleName": {
          "Fn::Sub": "${AWS::StackName}-contentful-webhook-function-role"
        }
      }
    },
    "UpdateGithubFunctionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "logs:CreateLogGroup",
                  "Resource": {
                    "Fn::Sub": "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:*"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": {
                    "Fn::Sub": [
                      "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/${FunctionName}:*",
                      {
                        "FunctionName": {
                          "Fn::Sub": "${AWS::StackName}-update-github-function"
                        }
                      }
                    ]
                  }
                }
              ]
            },
            "PolicyName": "AWSLambdaBasicExecutionRole"
          },
          {
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "secretsmanager:GetSecretValue",
                  "Resource": {
                    "Fn::ImportValue": {
                      "Fn::Sub": "${PersistentStackName}-SecretArn"
                    }
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListBucket",
                    "s3:GetObject",
                    "s3:PutObject"
                  ],
                  "Resource": [
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                      }
                    },
                    {
                      "Fn::Sub": [
                        "${DataBucketArn}/${DataGithubFileKey}",
                        {
                          "DataBucketArn": {
                            "Fn::ImportValue": {
                              "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": "ssm:GetParameter",
                  "Resource": {
                    "Fn::ImportValue": {
                      "Fn::Sub": "${PersistentStackName}-UpdateGithubPersonalAccessTokenParameterArn"
                    }
                  }
                }
              ]
            },
            "PolicyName": "CustomPolicy"
          }
        ],
        "RoleName": {
          "Fn::Sub": "${AWS::StackName}-update-github-function-role"
        }
      }
    },
    "WebAppFunctionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "logs:CreateLogGroup",
                  "Resource": {
                    "Fn::Sub": "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:*"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": {
                    "Fn::Sub": [
                      "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/${FunctionName}:*",
                      {
                        "FunctionName": {
                          "Fn::Sub": "${AWS::StackName}-web-app-function"
                        }
                      }
                    ]
                  }
                }
              ]
            },
            "PolicyName": "AWSLambdaBasicExecutionRole"
          },
          {
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "cloudfront:CreateInvalidation",
                  "Resource": {
                    "Fn::Sub": [
                      "arn:aws:cloudfront::${AWS::AccountId}:distribution/${DistributionId}",
                      {
                        "DistributionId": {
                          "Fn::ImportValue": {
                            "Fn::Sub": "${DistributionStackName}-DistributionId"
                          }
                        }
                      }
                    ]
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "secretsmanager:GetSecretValue",
                  "Resource": {
                    "Fn::ImportValue": {
                      "Fn::Sub": "${PersistentStackName}-SecretArn"
                    }
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:GetQueueAttributes",
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage"
                  ],
                  "Resource": {
                    "Fn::ImportValue": {
                      "Fn::Sub": "${PersistentStackName}-QueueArn"
                    }
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListBucket",
                    "s3:GetObject"
                  ],
                  "Resource": [
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                      }
                    },
                    {
                      "Fn::Sub": [
                        "${DataBucketArn}/${DataGithubFileKey}",
                        {
                          "DataBucketArn": {
                            "Fn::ImportValue": {
                              "Fn::Sub": "${PersistentStackName}-DataBucketArn"
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListBucket",
                    "s3:GetObject",
                    "s3:PutObject",
                    "s3:DeleteObject"
                  ],
                  "Resource": [
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-WebAppBucketArn"
                      }
                    },
                    {
                      "Fn::Sub": [
                        "${WebAppBucketArn}/*",
                        {
                          "WebAppBucketArn": {
                            "Fn::ImportValue": {
                              "Fn::Sub": "${PersistentStackName}-WebAppBucketArn"
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": "ssm:GetParameter",
                  "Resource": [
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-WebAppCmsAccessTokenParameterArn"
                      }
                    },
                    {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-WebAppCmsSpaceParameterArn"
                      }
                    }
                  ]
                }
              ]
            },
            "PolicyName": "CustomPolicy"
          }
        ],
        "RoleName": {
          "Fn::Sub": "${AWS::StackName}-web-app-function-role"
        }
      }
    },
    "CdUser": {
      "Type": "AWS::IAM::User",
      "Properties": {
        "ManagedPolicyArns": [
          {
            "Ref": "CdPolicy"
          }
        ],
        "UserName": {
          "Fn::Sub": "${AWS::StackName}-cd-user"
        }
      }
    },
    "DevUser": {
      "Type": "AWS::IAM::User",
      "Properties": {
        "ManagedPolicyArns": [
          {
            "Ref": "DevPolicy"
          }
        ],
        "UserName": {
          "Fn::Sub": "${AWS::StackName}-dev-user"
        }
      }
    },
    "WebAppFunctionEventSourceMapping": {
      "Type": "AWS::Lambda::EventSourceMapping",
      "Properties": {
        "BatchSize": 10000,
        "EventSourceArn": {
          "Fn::ImportValue": {
            "Fn::Sub": "${PersistentStackName}-QueueArn"
          }
        },
        "FunctionName": {
          "Ref": "WebAppFunction"
        },
        "MaximumBatchingWindowInSeconds": 300
      }
    },
    "ContentfulWebhookFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Architectures": [
          "arm64"
        ],
        "Code": {
          "S3Bucket": {
            "Fn::ImportValue": {
              "Fn::Sub": "${PersistentStackName}-DeploymentBucketName"
            }
          },
          "S3Key": "contentful-webhook.zip"
        },
        "Environment": {
          "Variables": {
            "PASSWORD_PARAMETER_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-ContentfulWebhookPasswordParameterName"
              }
            },
            "SECRET_ARN": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-SecretArn"
              }
            },
            "SECRET_CONTENTFUL_WEBHOOK_AUTH_PASSWORD_KEY": "CONTENTFUL_WEBHOOK_AUTH_PASSWORD",
            "SECRET_CONTENTFUL_WEBHOOK_AUTH_USERNAME_KEY": "CONTENTFUL_WEBHOOK_AUTH_USERNAME",
            "SQS_QUEUE_URL": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-QueueUrl"
              }
            },
            "USERNAME_PARAMETER_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-ContentfulWebhookUsernameParameterName"
              }
            }
          }
        },
        "FunctionName": {
          "Fn::Sub": "${AWS::StackName}-contentful-webhook-function"
        },
        "Handler": "index.handler",
        "Role": {
          "Fn::GetAtt": [
            "ContentfulWebhookFunctionRole",
            "Arn"
          ]
        },
        "Runtime": "nodejs24.x",
        "Timeout": 20
      }
    },
    "UpdateGithubFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Architectures": [
          "arm64"
        ],
        "Code": {
          "S3Bucket": {
            "Fn::ImportValue": {
              "Fn::Sub": "${PersistentStackName}-DeploymentBucketName"
            }
          },
          "S3Key": "update-github.zip"
        },
        "Environment": {
          "Variables": {
            "DATA_BUCKET_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-DataBucketName"
              }
            },
            "DATA_GITHUB_FILE_KEY": {
              "Ref": "DataGithubFileKey"
            },
            "GITHUB_BASE_URL": {
              "Ref": "UpdateGithubGithubBaseUrl"
            },
            "PERSONAL_ACCESS_TOKEN_PARAMETER_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-UpdateGithubPersonalAccessTokenParameterName"
              }
            },
            "SECRET_ARN": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-SecretArn"
              }
            },
            "SECRET_UPDATE_GITHUB_GITHUB_PERSONAL_ACCESS_TOKEN_KEY": "UPDATE_GITHUB_GITHUB_PERSONAL_ACCESS_TOKEN"
          }
        },
        "FunctionName": {
          "Fn::Sub": "${AWS::StackName}-update-github-function"
        },
        "Handler": "index.handler",
        "ReservedConcurrentExecutions": 1,
        "Role": {
          "Fn::GetAtt": [
            "UpdateGithubFunctionRole",
            "Arn"
          ]
        },
        "Runtime": "nodejs24.x",
        "Timeout": 60
      }
    },
    "WebAppFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "ImageUri": {
            "Fn::Sub": [
              "${WebAppRepositoryUri}:latest",
              {
                "WebAppRepositoryUri": {
                  "Fn::ImportValue": {
                    "Fn::Sub": "${PersistentStackName}-WebAppRepositoryUri"
                  }
                }
              }
            ]
          }
        },
        "Environment": {
          "Variables": {
            "BABEL_DISABLE_CACHE": "1",
            "CMS_ACCESS_TOKEN_PARAMETER_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-WebAppCmsAccessTokenParameterName"
              }
            },
            "CMS_SPACE_PARAMETER_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-WebAppCmsSpaceParameterName"
              }
            },
            "DATA_BUCKET_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-DataBucketName"
              }
            },
            "DATA_GITHUB_FILE_KEY": {
              "Ref": "DataGithubFileKey"
            },
            "LAMBDA_ACCESS_KEY_ID": "",
            "LAMBDA_DISTRIBUTION_ID": {
              "Fn::ImportValue": {
                "Fn::Sub": "${DistributionStackName}-DistributionId"
              }
            },
            "LAMBDA_INVALIDATION_PATH": {
              "Ref": "WebAppLambdaInvalidationPath"
            },
            "LAMBDA_REGION": {
              "Ref": "AWS::Region"
            },
            "LAMBDA_SECRET_ACCESS_KEY": "",
            "LAMBDA_USE_POLICY": "true",
            "LAMBDA_USE_TMPDIR": "true",
            "LAMBDA_WEB_APP_BUCKET_NAME": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-WebAppBucketName"
              }
            },
            "NPM_CONFIG_CACHE": "/tmp/.npm",
            "SECRET_ARN": {
              "Fn::ImportValue": {
                "Fn::Sub": "${PersistentStackName}-SecretArn"
              }
            },
            "SECRET_WEB_APP_CMS_CLIENT_ACCESS_TOKEN_KEY": "WEB_APP_CMS_CLIENT_ACCESS_TOKEN",
            "SECRET_WEB_APP_CMS_CLIENT_SPACE_KEY": "WEB_APP_CMS_CLIENT_SPACE"
          }
        },
        "FunctionName": {
          "Fn::Sub": "${AWS::StackName}-web-app-function"
        },
        "MemorySize": 3008,
        "PackageType": "Image",
        "ReservedConcurrentExecutions": 1,
        "Role": {
          "Fn::GetAtt": [
            "WebAppFunctionRole",
            "Arn"
          ]
        },
        "Timeout": 900
      }
    },
    "ContentfulWebhookFunctionPermission": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "Action": "lambda:InvokeFunctionUrl",
        "FunctionName": {
          "Ref": "ContentfulWebhookFunction"
        },
        "FunctionUrlAuthType": "NONE",
        "Principal": "*"
      }
    },
    "UpdateGithubRulePermission": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": {
          "Ref": "UpdateGithubFunction"
        },
        "Principal": "events.amazonaws.com",
        "SourceArn": {
          "Fn::GetAtt": [
            "UpdateGithubRule",
            "Arn"
          ]
        }
      }
    },
    "ContentfulWebhookFunctionUrl": {
      "Type": "AWS::Lambda::Url",
      "Properties": {
        "AuthType": "NONE",
        "TargetFunctionArn": {
          "Ref": "ContentfulWebhookFunction"
        }
      }
    }
  },
  "Outputs": {
    "ContentfulWebhookFunctionUrl": {
      "Value": {
        "Fn::GetAtt": [
          "ContentfulWebhookFunctionUrl",
          "FunctionUrl"
        ]
      },
      "Export": {
        "Name": {
          "Fn::Sub": "${AWS::StackName}-ContentfulWebhookFunctionUrl"
        }
      }
    }
  }
}
