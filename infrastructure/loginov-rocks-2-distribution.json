{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Parameters": {
    "DomainName": {
      "Type": "String",
      "Description": "Domain Name for Route 53"
    },
    "GoogleVerificationResourceRecord": {
      "Type": "String",
      "Default": "\"google-site-verification=QSpbzAoi-CcfCwDXcOi-UeUfxDPQXNAwfy70ICPZZok\""
    },
    "ICloudDkimHost": {
      "Type": "String",
      "Default": "sig1._domainkey"
    },
    "ICloudDkimResourceRecord": {
      "Type": "String",
      "Default": "sig1.dkim.loginov.rocks.at.icloudmailadmin.com."
    },
    "ICloudMxFirstResourceRecord": {
      "Type": "String",
      "Default": "10 mx01.mail.icloud.com."
    },
    "ICloudMxSecondResourceRecord": {
      "Type": "String",
      "Default": "20 mx02.mail.icloud.com."
    },
    "ICloudSpfResourceRecord": {
      "Type": "String",
      "Default": "\"v=spf1 include:icloud.com ~all\""
    },
    "ICloudTxtResourceRecord": {
      "Type": "String",
      "Default": "\"apple-domain=QLgz0KV1deSKUhlC\""
    },
    "PersistentStackName": {
      "Type": "String",
      "Description": "Name of previously deployed \"Persistent\" CloudFormation Stack"
    }
  },
  "Resources": {
    "Certificate": {
      "Type": "AWS::CertificateManager::Certificate",
      "Properties": {
        "DomainName": {
          "Ref": "DomainName"
        },
        "DomainValidationOptions": [
          {
            "DomainName": {
              "Ref": "DomainName"
            },
            "HostedZoneId": {
              "Ref": "HostedZone"
            }
          },
          {
            "DomainName": {
              "Fn::Sub": "www.${DomainName}"
            },
            "HostedZoneId": {
              "Ref": "HostedZone"
            }
          }
        ],
        "SubjectAlternativeNames": [
          {
            "Fn::Sub": "www.${DomainName}"
          }
        ],
        "ValidationMethod": "DNS"
      }
    },
    "WebAppBucketOriginAccessIdentity": {
      "Type": "AWS::CloudFront::CloudFrontOriginAccessIdentity",
      "Properties": {
        "CloudFrontOriginAccessIdentityConfig": {
          "Comment": {
            "Fn::Sub": "${AWS::StackName}-web-app-bucket-origin-access-identity"
          }
        }
      }
    },
    "Distribution": {
      "Type": "AWS::CloudFront::Distribution",
      "Properties": {
        "DistributionConfig": {
          "Aliases": [
            {
              "Ref": "DomainName"
            },
            {
              "Fn::Sub": "www.${DomainName}"
            }
          ],
          "CustomErrorResponses": [
            {
              "ErrorCode": 403,
              "ResponseCode": 200,
              "ResponsePagePath": "/index.html"
            }
          ],
          "DefaultCacheBehavior": {
            "CachePolicyId": "658327ea-f89d-4fab-a63d-7e88639e58f6",
            "Compress": true,
            "TargetOriginId": "WebAppBucketOrigin",
            "ViewerProtocolPolicy": "redirect-to-https"
          },
          "DefaultRootObject": "index.html",
          "Enabled": true,
          "HttpVersion": "http2",
          "Origins": [
            {
              "DomainName": {
                "Fn::Sub": [
                  "${WebAppBucketName}.s3.${AWS::Region}.amazonaws.com",
                  {
                    "WebAppBucketName": {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-WebAppBucketName"
                      }
                    }
                  }
                ]
              },
              "Id": "WebAppBucketOrigin",
              "S3OriginConfig": {
                "OriginAccessIdentity": {
                  "Fn::Sub": "origin-access-identity/cloudfront/${WebAppBucketOriginAccessIdentity}"
                }
              }
            }
          ],
          "ViewerCertificate": {
            "AcmCertificateArn": {
              "Ref": "Certificate"
            },
            "MinimumProtocolVersion": "TLSv1.2_2021",
            "SslSupportMethod": "sni-only"
          }
        }
      }
    },
    "HostedZone": {
      "Type": "AWS::Route53::HostedZone",
      "Properties": {
        "Name": {
          "Ref": "DomainName"
        }
      }
    },
    "RecordSetGroup": {
      "Type": "AWS::Route53::RecordSetGroup",
      "Properties": {
        "HostedZoneId": {
          "Ref": "HostedZone"
        },
        "RecordSets": [
          {
            "AliasTarget": {
              "DNSName": {
                "Fn::GetAtt": [
                  "Distribution",
                  "DomainName"
                ]
              },
              "HostedZoneId": "Z2FDTNDATAQYW2"
            },
            "Name": {
              "Ref": "DomainName"
            },
            "Type": "A"
          },
          {
            "AliasTarget": {
              "DNSName": {
                "Fn::GetAtt": [
                  "Distribution",
                  "DomainName"
                ]
              },
              "HostedZoneId": "Z2FDTNDATAQYW2"
            },
            "Name": {
              "Ref": "DomainName"
            },
            "Type": "AAAA"
          },
          {
            "AliasTarget": {
              "DNSName": {
                "Ref": "DomainName"
              },
              "HostedZoneId": {
                "Ref": "HostedZone"
              }
            },
            "Name": {
              "Fn::Sub": "www.${DomainName}"
            },
            "Type": "A"
          },
          {
            "AliasTarget": {
              "DNSName": {
                "Ref": "DomainName"
              },
              "HostedZoneId": {
                "Ref": "HostedZone"
              }
            },
            "Name": {
              "Fn::Sub": "www.${DomainName}"
            },
            "Type": "AAAA"
          },
          {
            "Name": {
              "Fn::Sub": "${ICloudDkimHost}.${DomainName}"
            },
            "ResourceRecords": [
              {
                "Ref": "ICloudDkimResourceRecord"
              }
            ],
            "TTL": "86400",
            "Type": "CNAME"
          },
          {
            "Name": {
              "Ref": "DomainName"
            },
            "ResourceRecords": [
              {
                "Ref": "ICloudMxFirstResourceRecord"
              },
              {
                "Ref": "ICloudMxSecondResourceRecord"
              }
            ],
            "TTL": "86400",
            "Type": "MX"
          },
          {
            "Name": {
              "Ref": "DomainName"
            },
            "ResourceRecords": [
              {
                "Ref": "GoogleVerificationResourceRecord"
              },
              {
                "Ref": "ICloudSpfResourceRecord"
              },
              {
                "Ref": "ICloudTxtResourceRecord"
              }
            ],
            "TTL": "86400",
            "Type": "TXT"
          }
        ]
      }
    },
    "WebAppBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": {
          "Fn::ImportValue": {
            "Fn::Sub": "${PersistentStackName}-WebAppBucketName"
          }
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::Sub": "arn:aws:iam::cloudfront:user/CloudFront Origin Access Identity ${WebAppBucketOriginAccessIdentity}"
                }
              },
              "Action": "s3:GetObject",
              "Resource": {
                "Fn::Sub": [
                  "${WebAppBucketArn}/*",
                  {
                    "WebAppBucketArn": {
                      "Fn::ImportValue": {
                        "Fn::Sub": "${PersistentStackName}-WebAppBucketArn"
                      }
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    }
  },
  "Outputs": {
    "DistributionId": {
      "Value": {
        "Ref": "Distribution"
      },
      "Export": {
        "Name": {
          "Fn::Sub": "${AWS::StackName}-DistributionId"
        }
      }
    }
  }
}
